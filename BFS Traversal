#include <vector>
#include <queue>

using namespace std;

class Solution {
  public:
    vector<int> bfs(vector<vector<int>> &adj) {
        int V = adj.size();             // Find the number of vertices
        vector<int> bfs_result;         // To store the final traversal order
        vector<bool> visited(V, false); // To keep track of visited nodes
        queue<int> q;                   // Queue for BFS
        
        // 1. Start from vertex 0
        q.push(0);
        visited[0] = true;
        
        // 2. Loop until the queue is empty
        while (!q.empty()) {
            int current_node = q.front();
            q.pop();
            
            // Add the current node to our result list
            bfs_result.push_back(current_node);
            
            // 3. Traverse all neighbors of the current node
            for (int neighbor : adj[current_node]) {
                // If the neighbor hasn't been visited yet, mark it and push to queue
                if (!visited[neighbor]) {
                    visited[neighbor] = true;
                    q.push(neighbor);
                }
            }
        }
        
        return bfs_result;
    }
};
